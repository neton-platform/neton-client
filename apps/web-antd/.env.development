# 端口号
VITE_PORT=5666

VITE_BASE=/

# 请求路径
VITE_BASE_URL=http://127.0.0.1:8088
# 接口地址
VITE_GLOB_API_URL=/app-api
# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=server
# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# client 端使用手机号登录，无默认用户名密码
